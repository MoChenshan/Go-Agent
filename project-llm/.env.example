# =====================================================
# project-llm 环境变量模板
# 使用：cp .env.example .env 然后填入真实值
# =====================================================

# ---------- 数据合成 LLM API ----------
# DeepSeek V3.2（方向一：知识库 QA 合成主力）
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# Moonshot Kimi-K2（方向二：NPC 对话合成主力，长上下文）
MOONSHOT_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
MOONSHOT_MODEL=moonshot-v1-128k

# OpenAI（judge / G-Eval 评估，可选）
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_JUDGE_MODEL=gpt-4o

# ---------- Embedding / Reranker ----------
# 本地 BGE-M3 或 GTE-Qwen2（留空则默认本地加载）
EMBED_MODEL=BAAI/bge-m3

# ---------- 训练观测 ----------
# SwanLab（国内可用的 W&B 替代）
SWANLAB_API_KEY=
SWANLAB_PROJECT=project-llm

# Langfuse 在线 Trace
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# OpenTelemetry（可选）
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=project-llm

# ---------- HuggingFace ----------
# 国内镜像（推荐），否则走官方
HF_ENDPOINT=https://hf-mirror.com
HF_TOKEN=

# ---------- ModelScope（可选）----------
MODELSCOPE_API_TOKEN=

# ---------- GPU 配置 ----------
CUDA_VISIBLE_DEVICES=0
# 是否启用 Flash Attention 3（仅 Hopper 架构 H100/H200）
USE_FA3=false
