# Required local switch.
WECOM_OPENCLAW_E2E=1

# Required remote claw identity.
WECOM_OPENCLAW_CLAW_ID=your_claw_id

# Required gateway auth headers used to fetch remote claw config.
WECOM_OPENCLAW_CLAW_AUTH_HEADERS='X-Gateway-Stage=TEST X-Gateway-SecretId=... X-Gateway-SecretKey=...'

# Optional remote claw config endpoint override.
# WECOM_OPENCLAW_CLAW_CONFIG_URL=http://api.apigw.oa.com/agui/claw/getClawConfig

# Optional base image override.
# WECOM_OPENCLAW_DOCKER_IMAGE=mirrors.tencent.com/todacc/agent_builder_claw:1.0.4

# Optional runner package override.
# WECOM_OPENCLAW_RUNNER_URL=https://mirrors.tencent.com/repository/generic/trpc-claw/v0.0.4/runner.tar.gz

# Optional judge override. Defaults to the same model config resolved from remote claw config.
# WECOM_OPENCLAW_JUDGE_MODEL=
# WECOM_OPENCLAW_JUDGE_API_KEY=
# WECOM_OPENCLAW_JUDGE_BASE_URL=

# Optional evaluation result output override.
# WECOM_OPENCLAW_EVAL_RESULT_DIR=

# The following model variables are expected to come from remote claw config, not from this file.
# OPENAI_MODEL=
# OPENAI_API_KEY=
# OPENAI_BASE_URL=
