ARG BASE_IMAGE=mirrors.tencent.com/todacc/trpc-golang-compile:0.3.2
ARG NODE_DIST_VERSION=v24.14.0
ARG NODE_DIST_BASE_URL=https://nodejs.org/dist
ARG OP_VERSION=2.33.0
ARG OP_DIST_BASE_URL=https://cache.agilebits.com/dist/1P/op2/pkg
ARG TORCH_INDEX_URL=https://download.pytorch.org/whl/cpu
ARG FFMPEG_STATIC_URL=https://johnvansickle.com/ffmpeg/releases/ffmpeg-7.0.2-amd64-static.tar.xz
ARG OPENCLAW_USER=openclaw
ARG OPENCLAW_UID=10001
ARG OPENCLAW_GID=10001
ARG OPENCLAW_HOME=/home/openclaw
ARG TRPC_CLAW_STATE_DIR=/home/openclaw/.trpc-agent-go/openclaw

FROM ${BASE_IMAGE}

SHELL ["/bin/bash", "-lc"]

ARG NODE_DIST_VERSION
ARG NODE_DIST_BASE_URL
ARG OP_VERSION
ARG OP_DIST_BASE_URL
ARG TORCH_INDEX_URL
ARG FFMPEG_STATIC_URL
ARG TRPC_CLAW_STATE_DIR
ARG OPENCLAW_USER
ARG OPENCLAW_UID
ARG OPENCLAW_GID
ARG OPENCLAW_HOME
ARG TARGETARCH
ARG GOPROXY=https://goproxy.woa.com,direct
ARG GOPRIVATE=trpc.group,trpc.tech
ARG GONOSUMDB=trpc.group,trpc.tech
ARG GONOPROXY=trpc.group,trpc.tech

ENV CARGO_HOME=/tmp/cargo-home \
    GOCACHE=/tmp/go-build-cache \
    GOMODCACHE=/tmp/go-mod-cache \
    GONOPROXY=${GONOPROXY} \
    GONOSUMDB=${GONOSUMDB} \
    GOPRIVATE=${GOPRIVATE} \
    GOPROXY=${GOPROXY} \
    GOROOT=/usr/local/go \
    GOTOOLCHAIN=auto \
    GOFLAGS=-buildvcs=false \
    HOME=${OPENCLAW_HOME} \
    NODE_HOME=/usr/local/node \
    NODE_PATH=/usr/local/node/lib/node_modules \
    NPM_CONFIG_UPDATE_NOTIFIER=false \
    PATH=${TRPC_CLAW_STATE_DIR}/toolchain/python/bin:/usr/local/node/bin:/usr/local/go/bin:/usr/local/bin:/usr/local/sbin:/usr/sbin:/usr/bin:/sbin:/bin \
    PIP_CACHE_DIR=/tmp/pip-cache \
    PIP_ROOT_USER_ACTION=ignore \
    PLAYWRIGHT_BROWSERS_PATH=${TRPC_CLAW_STATE_DIR}/playwright \
    PYTHONUNBUFFERED=1 \
    TRPC_CLAW_STATE_DIR=${TRPC_CLAW_STATE_DIR} \
    npm_config_cache=/tmp/npm-cache

RUN set -euo pipefail \
    && groupadd \
      --gid "${OPENCLAW_GID}" \
      "${OPENCLAW_USER}" \
    && useradd \
      --uid "${OPENCLAW_UID}" \
      --gid "${OPENCLAW_GID}" \
      --create-home \
      --home-dir "${OPENCLAW_HOME}" \
      --shell /bin/bash \
      "${OPENCLAW_USER}"

RUN dnf install -y \
      ImageMagick \
      alsa-lib-devel \
      bzip2 \
      cargo \
      ca-certificates \
      chromium \
      chromium-headless \
      chromedriver \
      curl \
      findutils \
      gcc \
      gcc-c++ \
      git \
      google-noto-cjk-fonts \
      google-noto-emoji-fonts \
      google-noto-sans-fonts \
      google-noto-sans-cjk-ttc-fonts \
      google-noto-serif-fonts \
      gzip \
      jq \
      libreoffice \
      make \
      openssl-devel \
      pandoc \
      pkgconf-pkg-config \
      poppler-utils \
      procps-ng \
      ripgrep \
      rust \
      tar \
      tesseract \
      tmux \
      unzip \
      which \
      xz \
    && dnf clean all \
    && rm -rf /var/cache/dnf

RUN set -euo pipefail \
    && cd /tmp \
    && curl -fsSLO \
      "${NODE_DIST_BASE_URL}/${NODE_DIST_VERSION}/SHASUMS256.txt" \
    && curl -fsSLO \
      "${NODE_DIST_BASE_URL}/${NODE_DIST_VERSION}/node-${NODE_DIST_VERSION}-linux-x64.tar.xz" \
    && grep " node-${NODE_DIST_VERSION}-linux-x64.tar.xz\$" \
      SHASUMS256.txt | sha256sum -c - \
    && mkdir -p /usr/local/node \
    && tar -xJf "node-${NODE_DIST_VERSION}-linux-x64.tar.xz" \
      -C /usr/local/node \
      --strip-components=1 \
    && ln -sf /usr/local/node/bin/corepack /usr/local/bin/corepack \
    && ln -sf /usr/local/node/bin/node /usr/local/bin/node \
    && ln -sf /usr/local/node/bin/npm /usr/local/bin/npm \
    && ln -sf /usr/local/node/bin/npx /usr/local/bin/npx \
    && rm -f \
      SHASUMS256.txt \
      "node-${NODE_DIST_VERSION}-linux-x64.tar.xz"

RUN set -euo pipefail \
    && arch="${TARGETARCH:-amd64}" \
    && case "$arch" in \
      amd64|arm64) opArch="$arch" ;; \
      *) echo "unsupported 1Password CLI arch: $arch" >&2; exit 1 ;; \
    esac \
    && opVersionDir="v${OP_VERSION}" \
    && opArchive="op_linux_${opArch}_v${OP_VERSION}.zip" \
    && opURL="${OP_DIST_BASE_URL}/${opVersionDir}/${opArchive}" \
    && curl -fsSL "$opURL" -o /tmp/op.zip \
    && mkdir -p /tmp/op-dist \
    && unzip -q /tmp/op.zip -d /tmp/op-dist \
    && install -m 0755 /tmp/op-dist/op /usr/local/bin/op \
    && rm -rf /tmp/op-dist /tmp/op.zip

RUN set -euo pipefail \
    && toolchain_root="${TRPC_CLAW_STATE_DIR}/toolchain/python" \
    && toolchain_bin_dir="${toolchain_root}/bin" \
    && install -d \
      "${TRPC_CLAW_STATE_DIR}" \
      "${TRPC_CLAW_STATE_DIR}/profiles" \
      "${TRPC_CLAW_STATE_DIR}/skills/bundled" \
      "${TRPC_CLAW_STATE_DIR}/skills/local" \
      "${TRPC_CLAW_STATE_DIR}/debug" \
      "${TRPC_CLAW_STATE_DIR}/tools" \
      "${TRPC_CLAW_STATE_DIR}/playwright" \
      "${HOME}/.codex" \
      "${HOME}/.gemini" \
      /workspace \
    && python3 -m venv "${toolchain_root}" \
    && "${toolchain_bin_dir}/python3" -m pip install --upgrade \
      pip \
      setuptools \
      wheel \
    && "${toolchain_bin_dir}/python3" -m pip install \
      anthropic \
      defusedxml \
      imageio \
      imageio-ffmpeg \
      lxml \
      mcp \
      numpy \
      openpyxl \
      pandas \
      pdf2image \
      pdfplumber \
      pillow \
      PyMuPDF \
      pypdf \
      PyPDF2 \
      pytesseract \
      python-docx \
      python-pptx \
      playwright \
      uv \
    && "${toolchain_bin_dir}/python3" -m pip install \
      --index-url "${TORCH_INDEX_URL}" \
      torch \
    && "${toolchain_bin_dir}/python3" -m pip install \
      openai-whisper \
    && npm install -g --prefix "${toolchain_root}" \
      @playwright/mcp@0.0.69 \
      @google/gemini-cli \
      @openai/codex \
      @steipete/oracle \
      @steipete/summarize \
      @xdevplatform/xurl \
      clawhub \
      mcporter \
    && GOBIN="${toolchain_bin_dir}" \
      go install github.com/Hyaxia/blogwatcher/cmd/blogwatcher@latest \
    && GOBIN="${toolchain_bin_dir}" \
      go install github.com/Yakitrak/notesmd-cli@latest \
    && GOBIN="${toolchain_bin_dir}" \
      go install github.com/cli/cli/v2/cmd/gh@latest \
    && GOBIN="${toolchain_bin_dir}" \
      go install github.com/steipete/blucli/cmd/blu@latest \
    && GOBIN="${toolchain_bin_dir}" \
      go install github.com/steipete/camsnap/cmd/camsnap@latest \
    && GOBIN="${toolchain_bin_dir}" \
      go install github.com/steipete/eightctl/cmd/eightctl@latest \
    && GOBIN="${toolchain_bin_dir}" \
      go install github.com/steipete/gifgrep/cmd/gifgrep@latest \
    && GOBIN="${toolchain_bin_dir}" \
      go install github.com/steipete/gogcli/cmd/gog@latest \
    && GOBIN="${toolchain_bin_dir}" \
      go install github.com/steipete/goplaces/cmd/goplaces@latest \
    && GOBIN="${toolchain_bin_dir}" \
      go install github.com/steipete/ordercli/cmd/ordercli@latest \
    && GOBIN="${toolchain_bin_dir}" \
      go install github.com/steipete/sag/cmd/sag@latest \
    && GOBIN="${toolchain_bin_dir}" \
      go install github.com/steipete/songsee/cmd/songsee@latest \
    && GOBIN="${toolchain_bin_dir}" \
      go install github.com/steipete/sonoscli/cmd/sonos@latest \
    && GOBIN="${toolchain_bin_dir}" \
      go install github.com/steipete/spogo/cmd/spogo@latest \
    && GOBIN="${toolchain_bin_dir}" \
      go install github.com/steipete/wacli/cmd/wacli@latest \
    && cargo install --locked --root "${toolchain_root}" himalaya \
    && git clone --depth 1 \
      https://github.com/openhue/openhue-cli.git \
      /tmp/openhue-src \
    && cd /tmp/openhue-src \
    && GOBIN="${toolchain_bin_dir}" go install . \
    && cd / \
    && ln -sf notesmd-cli "${toolchain_bin_dir}/obsidian-cli" \
    && ln -sf openhue-cli "${toolchain_bin_dir}/openhue" \
    && curl -fsSL "${FFMPEG_STATIC_URL}" -o /tmp/ffmpeg.tar.xz \
    && mkdir -p /tmp/ffmpeg-static \
    && tar -xJf /tmp/ffmpeg.tar.xz \
      -C /tmp/ffmpeg-static \
      --strip-components=1 \
    && install -m 0755 \
      /tmp/ffmpeg-static/ffmpeg \
      "${toolchain_bin_dir}/ffmpeg" \
    && install -m 0755 \
      /tmp/ffmpeg-static/ffprobe \
      "${toolchain_bin_dir}/ffprobe" \
    && "${toolchain_bin_dir}/python3" -m playwright install chromium \
    && chown -R \
      "${OPENCLAW_USER}:${OPENCLAW_USER}" \
      "${HOME}" \
      "${TRPC_CLAW_STATE_DIR}" \
      /workspace \
    && rm -rf \
      /tmp/cargo-home \
      /tmp/ffmpeg-static \
      /tmp/ffmpeg.tar.xz \
      /tmp/go-build-cache \
      /tmp/go-mod-cache \
      /tmp/npm-cache \
      /tmp/openhue-src \
      /tmp/pip-cache

ENV GIT_CONFIG_GLOBAL=${TRPC_CLAW_STATE_DIR}/gitconfig \
    OPENCLAW_GIT_CREDENTIALS_FILE=${TRPC_CLAW_STATE_DIR}/git-credentials

RUN install -d /usr/local/bin \
    && cat >/usr/local/bin/openclaw-entrypoint <<'EOF'
#!/usr/bin/env bash
set -euo pipefail

readonly defaultGitCredentialHost="git.woa.com"
readonly defaultGitCredentialProtocol="https"
readonly defaultGitCredentialUsername="oauth2"
readonly hostGitConfigPath="${HOME}/.gitconfig"

pick_git_token() {
  local name

  for name in \
    GIT_CREDENTIAL_TOKEN \
    GITLAB_TOKEN \
    GIT_TOKEN \
    OAUTH_TOKEN; do
    if [ -n "${!name:-}" ]; then
      printf '%s' "${!name}"
      return 0
    fi
  done

  return 1
}

ensure_git_config_root() {
  local globalConfigPath

  globalConfigPath="${GIT_CONFIG_GLOBAL:-${HOME}/.gitconfig}"
  mkdir -p "$(dirname "${globalConfigPath}")"
  touch "${globalConfigPath}"
  chmod 0600 "${globalConfigPath}"
}

maybe_include_host_gitconfig() {
  local globalConfigPath

  globalConfigPath="${GIT_CONFIG_GLOBAL:-${HOME}/.gitconfig}"
  if [ "${globalConfigPath}" = "${hostGitConfigPath}" ] ||
    [ ! -r "${hostGitConfigPath}" ]; then
    return 0
  fi

  if git config --global --get-all include.path |
    grep -Fxq "${hostGitConfigPath}"; then
    return 0
  fi

  git config --global --add include.path "${hostGitConfigPath}"
}

configure_git_defaults() {
  local credentialsFile

  credentialsFile="${OPENCLAW_GIT_CREDENTIALS_FILE:-}"
  if [ -z "${credentialsFile}" ]; then
    credentialsFile="${HOME}/.git-credentials"
  fi

  mkdir -p "$(dirname "${credentialsFile}")"
  touch "${credentialsFile}"
  chmod 0600 "${credentialsFile}"

  maybe_include_host_gitconfig
  git config --global \
    credential.helper \
    "store --file=${credentialsFile}"
  git config --global --replace-all safe.directory '*'
}

seed_git_credentials() {
  local token
  local host
  local protocol
  local username

  token="$(pick_git_token)" || return 0
  protocol="${GIT_CREDENTIAL_PROTOCOL:-${defaultGitCredentialProtocol}}"
  host="${GIT_CREDENTIAL_HOST:-${defaultGitCredentialHost}}"
  username="${GIT_CREDENTIAL_USERNAME:-${defaultGitCredentialUsername}}"

  git credential approve <<EOF_CREDENTIAL
protocol=${protocol}
host=${host}
username=${username}
password=${token}
EOF_CREDENTIAL
}

ensure_git_config_root
configure_git_defaults
seed_git_credentials

exec "$@"
EOF

RUN chmod 0755 /usr/local/bin/openclaw-entrypoint

USER ${OPENCLAW_USER}

WORKDIR /workspace

ENTRYPOINT ["/usr/local/bin/openclaw-entrypoint"]
CMD ["bash"]
