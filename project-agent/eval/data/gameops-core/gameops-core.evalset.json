  "evalCases": [
    {
      "evalId": "case_oom_diagnose",
      "conversation": [
        {
          "invocationId": "case_oom_diagnose-1",
          "userContent": {
            "role": "user",
            "content": "线上 pay-service 这两分钟收到 OOM 告警，帮我看下是哪个 Pod 在抖，给根因和下一步建议。"
          },
          "finalResponse": {
            "role": "assistant",
            "content": "根因：pay-service 在 BCS 集群 bcs-k8s-00001 有 2 个 Pod 处于 OOMKilled 状态，近 5 分钟 container_memory_working_set_bytes 超过 limit 阈值（1.2GiB/1GiB）。建议：1) 先扩 limit 至 2GiB 止血；2) RepairAgent 发起 Helm upgrade 走 HITL 确认；3) 记录 TAPD Bug 跟踪 heap dump 分析。"
          },
          "tools": [
            {
              "id": "tool_use_1",
              "name": "bk_alarm_query",
              "arguments": {
                "biz_id": 100,
                "service": "pay-service",
                "time_range": "5m"
              },
              "result": {
                "alarms": [
                  {
                    "id": "A-1001",
                    "level": "critical",
                    "metric": "container_memory_working_set_bytes",
                    "target": "pay-service"
                  }
                ]
              }
            },
            {
              "id": "tool_use_2",
              "name": "bcs_resource_query",
              "arguments": {
                "cluster_id": "bcs-k8s-00001",
                "namespace": "default",
                "kind": "Pod",
                "label_selector": "app=pay-service"
              },
              "result": {
                "items": [
                  {
                    "name": "pay-service-0",
                    "status": "OOMKilled",
                    "restartCount": 3
                  },
                  {
                    "name": "pay-service-1",
                    "status": "OOMKilled",
                    "restartCount": 2
                  }
                ]
              }
            },
            {
              "id": "tool_use_3",
              "name": "bk_metrics_query",
              "arguments": {
                "promql": "max(container_memory_working_set_bytes{pod=~\"pay-service-.*\"}) by (pod)",
                "time_range": "5m"
              },
              "result": {
                "series": [
                  {
                    "metric": {"pod": "pay-service-0"},
                    "values": [[1712345678, "1287651328"]]
                  }
                ]
              }
            }
          ]
        }
      ],
      "sessionInput": {
        "appName": "gameops-agent",
        "userId": "eval-user"
      }
    },
