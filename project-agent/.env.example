# =====================================================
# GameOps Agent — 环境变量模板
# 用法：cp .env.example .env  然后填入真实值
# 该文件被 docker-compose.yml 自动加载（同目录）
# =====================================================

# ---------- LLM 模型 ----------
# 司内（混元）
# OPENAI_API_KEY=<your-hunyuan-api-key>
# OPENAI_BASE_URL=http://hunyuanapi.woa.com/openapi/v1
# MODEL_NAME=hunyuan-turbo-s

# 司外（DeepSeek 示例）
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://api.deepseek.com/v1
MODEL_NAME=deepseek-chat

# 也可指向自建 vLLM（与 project-llm 联动时）
# OPENAI_BASE_URL=http://host.docker.internal:8000/v1
# OPENAI_API_KEY=any
# MODEL_NAME=knowledge-expert

# ---------- 知识库 / Embedding ----------
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
KNOWLEDGE_DATA_DIR=data/knowledge
# KNOWLEDGE_DISABLE=1                # 强制禁用 RAG（本地无 Embedding API 时）

# ---------- 蓝鲸监控（不配走 Mock） ----------
BK_APP_CODE=
BK_APP_SECRET=
BK_APIGW_BASE_URL=https://bkapi.paas.woa.com
BK_API_MOCK=1                        # 司外必须为 1

# ---------- BCS 容器平台 ----------
BCS_GATEWAY_URL=
BCS_TOKEN=
BCS_API_MOCK=1                       # 司外必须为 1

# ---------- 工蜂 Git ----------
GONGFENG_TOKEN=
GONGFENG_BASE_URL=https://git.woa.com/api/v3
GONGFENG_API_MOCK=1                  # 司外必须为 1
GONGFENG_ALLOW_AUTO_MERGE=0          # 默认关，按治理流程开

# ---------- 蓝盾 CI/CD ----------
DEVOPS_TOKEN=
DEVOPS_USER=
DEVOPS_BASE_URL=https://devops.woa.com
DEVOPS_API_MOCK=1                    # 司外必须为 1
DEVOPS_ALLOW_AUTO_OPS=0              # 默认关

# ---------- TAPD ----------
TAPD_USER=
TAPD_TOKEN=
TAPD_WORKSPACE_ID=
TAPD_BASE_URL=https://api.tapd.cn
TAPD_API_MOCK=1                      # 司外必须为 1

# ---------- iWiki 知识库 ----------
IWIKI_PAAS_ID=
IWIKI_TOKEN=

# ---------- HITL（人审）----------
# 生产环境永远不要设为 1
HITL_DISABLE=0

# ---------- 文件分析沙盒 ----------
FILE_ANALYZE_ROOT=data/samples

# ---------- Session（Redis） ----------
SESSION_BACKEND=redis
SESSION_REDIS_ADDR=redis:6379
SESSION_EVENT_THRESHOLD=20

# ---------- 幂等键（Redis） ----------
IDEMPOTENCY_BACKEND=redis
IDEMPOTENCY_REDIS_ADDR=redis:6379
IDEMPOTENCY_TTL=24h

# ---------- 审计 ----------
# 强烈建议生产用 ExternalSecrets / Vault 注入
AUDIT_HMAC_KEY=dev-only-not-for-prod-please-rotate
AUDIT_SINK=file
AUDIT_FILE_PATH=/app/audit.log

# ---------- OpenTelemetry ----------
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_SERVICE_NAME=gameops-agent
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=0.3

# ---------- Langfuse ----------
LANGFUSE_HOST=http://langfuse:3000
LANGFUSE_PUBLIC_KEY=pk-lf-stub
LANGFUSE_SECRET_KEY=sk-lf-stub
